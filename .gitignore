# --- Server runtime artefacts ---
# Anchored to repo root so we don't accidentally ignore the source/test
# `Audit/` folders on case-insensitive filesystems.
/.pbi-modeling-mcp/
/audit/
/backups/

# --- azd environment state (per-deploy secrets, never commit) ---
# `azd up` writes the resolved env vars (including HTTP_AUTH_TOKEN) under
# .azure/<env-name>/.env. Treat the whole tree as gitignored.
.azure/
