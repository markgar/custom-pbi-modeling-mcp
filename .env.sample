# PBI Modeling MCP — sample environment file.
# Copy to `.env` (gitignored) and fill in. Real env vars always win over
# this file. See SPEC.md for the full env-var reference.

# --- Optional: server defaults ---------------------------------------------
# PBI_MCP__AuditDir=~/.pbi-modeling-mcp
# PBI_MCP__RequireConfirmDelete=true
# PBI_MCP__LogLevel=Information
# PBI_MCP__Actor=alex@laptop

# --- Transport ------------------------------------------------------------
# Default for local dev: HTTP transport on loopback with auth DISABLED.
# Safe because:
#   - HttpHost=127.0.0.1 means only your own machine can reach the port
#   - the server emits a loud "AUTH DISABLED" banner on every launch
#   - fail-closed startup checks refuse to bind anywhere reachable in
#     this configuration without an explicit second opt-in
# In production (App Service / Container Apps), Bicep sets HttpAuthToken
# and does NOT set HttpDisableAuth, so the API-key gate is active.
PBI_MCP__Transport=http
PBI_MCP__HttpHost=127.0.0.1
PBI_MCP__HttpPort=5000
PBI_MCP__HttpDisableAuth=true

# --- HTTP transport: production / non-loopback shapes --------------------
# Uncomment + set HttpAuthToken (and remove HttpDisableAuth above) when
# binding anywhere reachable. Shared-secret API key, ANYONE with this
# value gets the server's Power BI identity — single-tenant only.
#
# Generate one of:
#   PowerShell: $rng = [System.Security.Cryptography.RandomNumberGenerator]::Create(); $b = New-Object byte[] 32; $rng.GetBytes($b); [Convert]::ToBase64String($b)
#   bash:       openssl rand -base64 32
#
# The literal "REPLACE_ME_WITH_A_SECURE_RANDOM_STRING" is on the sentinel
# rejection list — the server refuses to start if you leave it as-is.
# PBI_MCP__HttpAuthToken=REPLACE_ME_WITH_A_SECURE_RANDOM_STRING
#
# Required to bind a non-loopback HttpHost without TLS. Off by default so
# the API key is never shipped over cleartext by accident. Run behind
# a TLS-terminating reverse proxy and only flip this to true if you
# understand the consequences.
# PBI_MCP__HttpAllowInsecure=false

# --- Platform-managed hosting (App Service, ACA, AKS ingress) -------------
# When true: bind on *:{port} (all interfaces); resolve {port} from
#   PORT  →  WEBSITES_PORT  →  PBI_MCP__HttpPort
# (App Service injects PORT; ACA respects the same convention.) The
# loopback / IP-parse / cleartext-secret guardrails are skipped because
# TLS termination is the platform's job, not ours. HttpHost is ignored
# in this mode.
# PBI_MCP__HttpListenAllInterfaces=false
